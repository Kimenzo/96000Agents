{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "index.ts",
    "boot.ts",
    "core/**/*.ts",
    "agents/**/*.ts",
    "workflows/**/*.ts",
    "optimizers/**/*.ts",
    "evaluators/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "__tests__",
    "**/*.test.ts"
  ]
}
